[gd_scene load_steps=5 format=3]

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_bullet"]
shading_mode = 0
albedo_color = Color(1, 1, 0, 1)

[sub_resource type="SphereMesh" id="SphereMesh_bullet"]
material = SubResource("StandardMaterial3D_bullet")
radius = 0.1
height = 0.2

[sub_resource type="SphereShape3D" id="SphereShape3D_bullet"]
radius = 0.1

[sub_resource type="GDScript" id="GDScript_bullet"]
script/source = "extends Node3D

var target: Node3D = null
var speed: float = 20.0
var damage: int = 10

func _process(delta: float) -> void:
	if not is_instance_valid(target):
		queue_free()
		return
		
	var dir = (target.global_position + Vector3(0, 0.9, 0) - global_position).normalized()
	global_position += dir * speed * delta
	
	if global_position.distance_to(target.global_position + Vector3(0, 0.9, 0)) < 0.5:
		if target.has_method(\"take_damage\"):
			target.take_damage(damage)
		queue_free()
"

[node name="Bullet" type="Node3D"]
script = SubResource("GDScript_bullet")

[node name="MeshInstance3D" type="MeshInstance3D" parent="."]
mesh = SubResource("SphereMesh_bullet")

[node name="Area3D" type="Area3D" parent="."]

