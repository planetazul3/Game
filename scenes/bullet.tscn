[sub_resource type="GDScript" id="GDScript_bullet"]
script/source = "extends Node3D

var target: Node3D = null
var damage: int = 10
var speed: float = 25.0
var source_unit: Node3D = null
var _bullet_color: Color = Color(1, 1, 0, 1)

func set_color(c: Color) -> void:
	_bullet_color = c
	var mesh_node = $MeshInstance3D
	if mesh_node:
		var mat = StandardMaterial3D.new()
		mat.shading_mode = StandardMaterial3D.SHADING_MODE_UNSHADED
		mat.albedo_color = c
		mat.emission_enabled = true
		mat.emission = c
		mat.emission_energy_multiplier = 3.0
		mesh_node.set_surface_override_material(0, mat)
	var trail = $Trail
	if trail:
		trail.color = c

func _physics_process(delta: float):
	if not is_instance_valid(target):
		queue_free()
		return
		
	var target_center = target.global_position + Vector3(0, 0.9, 0)
	var dir = (target_center - global_position).normalized()
	global_position += dir * speed * delta
	
	if global_position.distance_to(target_center) < 0.5:
		if target.has_method(\"take_damage\"):
			var src_pos = source_unit.global_position if is_instance_valid(source_unit) else global_position
			target.take_damage(damage, src_pos)
		queue_free()
"

